    "## 2. Build the model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "62dbde4e",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-14T15:55:48.170617Z",
     "iopub.status.busy": "2026-07-14T15:55:48.170361Z",
